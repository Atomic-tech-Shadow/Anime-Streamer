{
  "expo": {
    "name": "ATOMIC FLIX",
    "slug": "atomic-flix",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon_preview.png",
    "scheme": "atomic-flix",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#08080F"
    },
    "updates": {
      "url": "https://u.expo.dev/a66c76df-7de1-48d3-ba6f-587b776ba633",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": "1.0.0",
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "backgroundColor": "#08080F",
      "package": "com.atomicflix.app",
      "usesCleartextTraffic": true,
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon_preview.png",
        "backgroundColor": "#08080F"
      }
    },
    "web": {
      "favicon": "./assets/images/icon_preview.png",
      "backgroundColor": "#08080F"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#08080F",
          "image": "./assets/images/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "android": {
            "backgroundColor": "#08080F",
            "image": "./assets/images/splash.png",
            "imageWidth": 200,
            "resizeMode": "contain"
          }
        }
      ],
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-updates",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon_preview.png",
          "color": "#7c3aed",
          "iosDisplayInForeground": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "a66c76df-7de1-48d3-ba6f-587b776ba633"
      }
    },
    "owner": "marcosoroko"
  }
}
