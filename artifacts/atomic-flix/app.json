{
  "expo": {
    "name": "ATOMIC FLIX",
    "slug": "atomic-flix",
    "owner": "cidmarco",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "atomic-flix",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#08080F"
    },
    "updates": {
      "url": "https://u.expo.dev/4a82031b-ff3f-479b-9e88-d0d38ff656d8",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "backgroundColor": "#08080F",
      "package": "com.animestreamer.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#08080F"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "backgroundColor": "#08080F"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-updates",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#7c3aed",
          "iosDisplayInForeground": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "4a82031b-ff3f-479b-9e88-d0d38ff656d8"
      }
    }
  }
}
